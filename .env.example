# 必填：后台管理密码（请修改）
ADMIN_KEY=change_me_to_a_strong_password

# 可选：RSSHub 基础地址
RSS_BASE=https://rsshub.app

# 可选：时区
TZ=Asia/Shanghai

# 可选：宿主机映射端口（对外访问 http://服务器IP:APP_PORT）
APP_PORT=6666

# 可选：代理
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 可选：翻译能力（task.translate > 0 时才会使用）
# OPENAI_KEY=
# OPENAI_API_BASE=https://openai.api2d.net
# TRANSLATE_MAX_LEN=8000
